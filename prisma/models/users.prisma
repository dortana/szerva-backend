model User {
    id                 String @id @default(uuid())

    firstName          String
    lastName           String

    email              String    @unique
    emailVerified      DateTime?
    phone              String?   @unique
    phoneVerified      DateTime?

    passwordHash       String

    image              String?
    role               UserRole   @default(CUSTOMER)
    status             UserStatus @default(NEW)

    dateOfBirth        String?

    addresses          Address[]

    verified           Boolean @default(false)

    twoFactorEnabled   Boolean @default(false)

    onBoardingStatus   OnBoardingStatus? @default(NOT_STARTED)
    expertiseDetails   Expertise[]

    documents          Document[]

    createdAt          DateTime @default(now())
    updatedAt          DateTime @default(now()) @updatedAt

    sessions           Session[]

    userOrders         Order[] @relation("OrderUser")
    expertOrders       Order[] @relation("OrderExpert")

    reviewsGiven       Review[] @relation("ReviewAuthor")
    reviewsReceived    Review[] @relation("ReviewTarget")

    selectedLocation   Location? @relation(fields: [selectedLocationId], references: [id])
    selectedLocationId String?

    @@map("users")
  
}

enum UserRole {
    CUSTOMER
    ADMIN
    EXPERT
    EMPLOYEE
}

enum UserStatus {
    ACTIVE
    BLOCKED
    BANNED
    DISABLED
    NEW
    DELETED
}

enum OnBoardingStatus {
    NOT_STARTED
    PERSONAL_INFO
    PHONE_VERIFICATION
    ADDRESS_INFO
    EXPERTISE_INFO
    DOCUMENTS_UPLOAD
    UNDER_REVIEW
    COMPLETED
}

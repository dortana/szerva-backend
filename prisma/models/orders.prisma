model Order {
  id        String @id @default(uuid())
  title     String

  userId    String
  user      User @relation("OrderUser", fields: [userId], references: [id], onDelete: Cascade)

  expertId String?
  expert   User? @relation("OrderExpert", fields: [expertId], references: [id], onDelete: Cascade)

  orderId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, orderId, expertId])
  @@map("orders")
}
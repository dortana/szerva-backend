model Address {
  id           String @id @default(uuid())

  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  postalCode   String
  country      String
  countryCode  String

  unit         String? // apartment / door number
  floor        String? // floor
  building     String? // building name / block / entrance
  entrance     String? // staircase / подъезд / lépcsőház
  notes        String? // delivery instructions

  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isPrimary    Boolean @default(false)

  companyName  String?
  vatNumber    String?

  email        String?
  phone        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("addresses")
}
